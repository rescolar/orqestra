generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  password          String?
  name              String
  avatar_url        String?
  role              UserRole             @default(organizer)
  created_at        DateTime             @default(now())
  brand_bg_color    String?
  brand_name        String?
  brand_text_color  String?
  brand_welcome_msg String?
  google_id         String?              @unique
  environment       OrganizerEnvironment @default(open)
  slug              String?              @unique
  collaborations    EventCollaborator[]
  events            Event[]
  self_person       Person[]             @relation("SelfPerson")
  persons           Person[]
  venues            Venue[]

  @@map("users")
}

model Person {
  id                   String        @id @default(cuid())
  user_id              String
  name_full            String
  name_display         String
  name_initials        String
  default_role         PersonRole    @default(participant)
  gender               Gender        @default(unknown)
  contact_email        String?
  contact_phone        String?
  contact_address      String?
  dietary_requirements String[]      @default([])
  allergies_text       String?
  notes                String?
  created_at           DateTime      @default(now())
  avatar_url           String?
  self_user_id         String?
  discoverable         Boolean       @default(true)
  event_persons        EventPerson[]
  self_user            User?         @relation("SelfPerson", fields: [self_user_id], references: [id])
  user                 User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, self_user_id])
  @@map("persons")
}

model Event {
  id                         String               @id @default(cuid())
  user_id                    String
  name                       String
  date_start                 DateTime
  date_end                   DateTime
  estimated_participants     Int
  status                     EventStatus          @default(draft)
  description                String?
  location                   String?
  image_url                  String?
  invite_code                String?              @unique
  schedule_confirmed         Boolean              @default(false)
  collab_invite_code         String?              @unique
  participant_discovery      Boolean              @default(false)
  deposit_amount             Decimal?             @db.Decimal(10, 2)
  event_price                Decimal?             @db.Decimal(10, 2)
  pricing_by_room_type       Boolean              @default(false)
  meal_cost_breakfast        Decimal?             @db.Decimal(10, 2)
  meal_cost_dinner           Decimal?             @db.Decimal(10, 2)
  meal_cost_lunch            Decimal?             @db.Decimal(10, 2)
  venue_id                   String?
  facilitation_cost_day      Decimal?             @db.Decimal(10, 2)
  facilitation_cost_half_day Decimal?             @db.Decimal(10, 2)
  management_cost_day        Decimal?             @db.Decimal(10, 2)
  pricing_mode               String               @default("direct")
  show_accommodation         Boolean              @default(false)
  show_availability          Boolean              @default(false)
  centro_share_token         CentroShareToken?
  collaborators              EventCollaborator[]
  event_persons              EventPerson[]
  user                       User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  venue                      Venue?               @relation(fields: [venue_id], references: [id])
  groups                     Group[]
  relationship_invites       RelationshipInvite[]
  room_pricings              RoomPricing[]
  rooms                      Room[]
  schedule_blocks            ScheduleBlock[]
  undo_entries               UndoEntry[]
  cost_items                 EventCostItem[]

  @@map("events")
}

model EventPerson {
  id                             String            @id @default(cuid())
  event_id                       String
  person_id                      String
  role                           PersonRole        @default(participant)
  status                         EventPersonStatus @default(inscrito)
  group_id                       String?
  dietary_notified               Boolean           @default(false)
  requests_text                  String?
  requests_managed               Boolean           @default(false)
  room_id                        String?
  arrives_for_dinner             Boolean           @default(true)
  last_meal_lunch                Boolean           @default(true)
  checked_in_at                  DateTime?
  amount_paid                    Decimal?          @db.Decimal(10, 2)
  payment_note                   String?
  companion_id                   String?
  date_arrival                   DateTime?
  date_departure                 DateTime?
  discount_breakfast             Int               @default(0)
  discount_dinner                Int               @default(0)
  discount_lunch                 Int               @default(0)
  accommodation_mismatch_managed Boolean           @default(false)
  accommodation_occupancy        Int?
  accommodation_room_type_id     String?
  auto_assign_managed            Boolean           @default(false)
  auto_assigned                  Boolean           @default(false)
  activity_signups               ActivitySignup[]
  event                          Event             @relation(fields: [event_id], references: [id], onDelete: Cascade)
  group                          Group?            @relation(fields: [group_id], references: [id])
  person                         Person            @relation(fields: [person_id], references: [id], onDelete: Cascade)
  room                           Room?             @relation(fields: [room_id], references: [id])
  meal_attendances               MealAttendance[]
  cost_items                     EventCostItem[]

  @@unique([event_id, person_id])
  @@map("event_persons")
}

model Room {
  id                    String            @id @default(cuid())
  event_id              String
  internal_number       String
  display_name          String?
  icon                  String?
  capacity              Int
  has_private_bathroom  Boolean           @default(false)
  gender_restriction    GenderRestriction @default(mixed)
  description           String?
  tags                  String[]          @default([])
  conflict_acknowledged Boolean           @default(false)
  locked                Boolean           @default(false)
  locked_reason         String?
  room_type_id          String?
  event_persons         EventPerson[]
  event                 Event             @relation(fields: [event_id], references: [id], onDelete: Cascade)
  room_type             RoomType?         @relation(fields: [room_type_id], references: [id])

  @@map("rooms")
}

model RoomPricing {
  id                   String   @id @default(cuid())
  event_id             String
  capacity             Int
  has_private_bathroom Boolean
  price                Decimal  @db.Decimal(10, 2)
  daily_rate           Decimal? @db.Decimal(10, 2)
  event                Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@unique([event_id, capacity, has_private_bathroom])
  @@map("room_pricings")
}

model Group {
  id       String        @id @default(cuid())
  event_id String
  name     String
  members  EventPerson[]
  event    Event         @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@map("groups")
}

model CentroShareToken {
  id         String   @id @default(cuid())
  event_id   String   @unique
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())
  event      Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@map("centro_share_tokens")
}

model ScheduleBlock {
  id         String             @id @default(cuid())
  event_id   String
  day_index  Int
  position   Int
  type       ScheduleBlockType
  time_label String?
  activities ScheduleActivity[]
  event      Event              @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@map("schedule_blocks")
}

model ScheduleActivity {
  id               String           @id @default(cuid())
  block_id         String
  title            String
  description      String?
  position         Int
  closed           Boolean          @default(false)
  max_participants Int?
  signups          ActivitySignup[]
  block            ScheduleBlock    @relation(fields: [block_id], references: [id], onDelete: Cascade)

  @@map("schedule_activities")
}

model ActivitySignup {
  id              String           @id @default(cuid())
  activity_id     String
  event_person_id String
  confirmed       Boolean          @default(false)
  activity        ScheduleActivity @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  event_person    EventPerson      @relation(fields: [event_person_id], references: [id], onDelete: Cascade)

  @@unique([activity_id, event_person_id])
  @@map("activity_signups")
}

model MealAttendance {
  id              String      @id @default(cuid())
  event_person_id String
  day_index       Int
  breakfast       Boolean     @default(true)
  lunch           Boolean     @default(true)
  dinner          Boolean     @default(true)
  event_person    EventPerson @relation(fields: [event_person_id], references: [id], onDelete: Cascade)

  @@unique([event_person_id, day_index])
  @@map("meal_attendances")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  token      String   @unique
  email      String
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

model UndoEntry {
  id        String   @id @default(cuid())
  event_id  String
  batch_id  String
  type      UndoType
  snapshot  Json
  timestamp DateTime @default(now())
  event     Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@map("undo_entries")
}

model EventCollaborator {
  id       String @id @default(cuid())
  event_id String
  user_id  String
  event    Event  @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([event_id, user_id])
  @@map("event_collaborators")
}

model AdminInviteToken {
  id         String   @id @default(cuid())
  token      String   @unique
  created_by String
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("admin_invite_tokens")
}

model RelationshipInvite {
  id                String           @id @default(cuid())
  event_id          String
  sender_user_id    String
  recipient_email   String?
  recipient_user_id String?
  relationship_type RelationshipType
  token             String           @unique
  status            InviteStatus     @default(pending)
  expires_at        DateTime
  created_at        DateTime         @default(now())
  resolved_at       DateTime?
  event             Event            @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@map("relationship_invites")
}

model Venue {
  id          String     @id @default(cuid())
  user_id     String
  name        String
  location    String?
  notes       String?
  is_template Boolean    @default(true)
  events      Event[]
  room_types  RoomType[]
  user        User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("venues")
}

model RoomType {
  id                   String             @id @default(cuid())
  venue_id             String
  name                 String
  description          String?
  capacity             Int
  has_private_bathroom Boolean            @default(false)
  base_price           Decimal?           @db.Decimal(10, 2)
  position             Int                @default(0)
  occupancy_pricings   OccupancyPricing[]
  venue                Venue              @relation(fields: [venue_id], references: [id], onDelete: Cascade)
  rooms                Room[]

  @@map("room_types")
}

model OccupancyPricing {
  id           String   @id @default(cuid())
  room_type_id String
  occupancy    Int
  price        Decimal  @db.Decimal(10, 2)
  room_type    RoomType @relation(fields: [room_type_id], references: [id], onDelete: Cascade)

  @@unique([room_type_id, occupancy])
  @@map("occupancy_pricings")
}

model EventCostItem {
  id              String            @id @default(cuid())
  event_id        String
  event_person_id String?
  scope           EventCostScope
  category        EventCostCategory
  title           String
  description     String?
  quantity        Decimal?          @db.Decimal(10, 2)
  unit_amount     Decimal?          @db.Decimal(10, 2)
  total_amount    Decimal           @db.Decimal(10, 2)
  currency        String            @default("EUR")
  status          EventCostStatus   @default(planned)
  source          String            @default("cost_manager")
  created_at      DateTime          @default(now())
  updated_at      DateTime          @default(now()) @updatedAt
  event           Event             @relation(fields: [event_id], references: [id], onDelete: Cascade)
  event_person    EventPerson?      @relation(fields: [event_person_id], references: [id], onDelete: SetNull)

  @@index([event_id, source])
  @@index([event_person_id])
  @@map("event_cost_items")
}

enum UserRole {
  organizer
  admin
  participant
}

enum OrganizerEnvironment {
  open
  private
}

enum Gender {
  unknown
  female
  male
  other
}

enum PersonRole {
  participant
  facilitator
}

enum EventStatus {
  draft
  active
  archived
  published
  finished
}

enum EventPersonStatus {
  inscrito
  reservado
  pagado
  confirmado_sin_pago
  solicita_cancelacion
  cancelado
}

enum GenderRestriction {
  mixed
  women
  men
}

enum ScheduleBlockType {
  common
  parallel
}

enum UndoType {
  assign_person
  link_persons
}

enum RelationshipType {
  inseparable
  flexible
}

enum InviteStatus {
  pending
  accepted
  declined
  expired
}

enum EventCostScope {
  event
  facilitator
}

enum EventCostCategory {
  facilitator_fee
  facilitator_lodging
  extra_cost
  organization_profit
}

enum EventCostStatus {
  planned
}
