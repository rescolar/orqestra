generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────

enum UserRole {
  organizer
  admin
  participant
}

enum OrganizerEnvironment {
  open
  private
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String?
  name        String
  avatar_url        String?
  role              UserRole @default(organizer)
  google_id         String?  @unique
  environment       OrganizerEnvironment @default(open)
  slug              String?  @unique
  brand_name        String?
  brand_welcome_msg String?
  brand_bg_color    String?
  brand_text_color  String?
  created_at  DateTime @default(now())

  persons        Person[]
  events         Event[]
  self_person    Person[] @relation("SelfPerson")
  collaborations EventCollaborator[]

  @@map("users")
}

// ─── Person ──────────────────────────────────────────────────────────────────

enum Gender {
  unknown
  female
  male
  other
}

enum PersonRole {
  participant
  facilitator
}

model Person {
  id                   String     @id @default(cuid())
  user_id              String
  name_full            String
  name_display         String
  name_initials        String
  default_role         PersonRole @default(participant)
  gender               Gender     @default(unknown)
  contact_email        String?
  contact_phone        String?
  contact_address      String?
  avatar_url           String?
  dietary_requirements String[]   @default([])
  allergies_text       String?
  notes                String?
  created_at           DateTime   @default(now())

  self_user_id  String?
  discoverable  Boolean       @default(true)
  user          User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  self_user     User?         @relation("SelfPerson", fields: [self_user_id], references: [id], onDelete: SetNull)
  event_persons EventPerson[]

  @@unique([user_id, self_user_id])
  @@map("persons")
}

// ─── Event ───────────────────────────────────────────────────────────────────

enum EventStatus {
  draft
  active
  archived
}

model Event {
  id                     String      @id @default(cuid())
  user_id                String
  name                   String
  date_start             DateTime
  date_end               DateTime
  estimated_participants Int
  status                 EventStatus @default(draft)
  description            String?
  location               String?
  image_url              String?
  invite_code            String?         @unique
  collab_invite_code     String?         @unique
  participant_discovery  Boolean         @default(false)
  schedule_confirmed     Boolean         @default(false)
  event_price            Decimal?        @db.Decimal(10, 2)
  deposit_amount         Decimal?        @db.Decimal(10, 2)

  user                User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event_persons       EventPerson[]
  rooms               Room[]
  groups              Group[]
  undo_entries        UndoEntry[]
  centro_share_token  CentroShareToken?
  schedule_blocks     ScheduleBlock[]
  collaborators       EventCollaborator[]
  relationship_invites RelationshipInvite[]

  @@map("events")
}

// ─── EventPerson ─────────────────────────────────────────────────────────────

enum EventPersonStatus {
  inscrito
  reservado
  pagado
  confirmado_sin_pago
  solicita_cancelacion
  cancelado
}

model EventPerson {
  id                   String            @id @default(cuid())
  event_id             String
  person_id            String
  role                 PersonRole        @default(participant)
  status               EventPersonStatus @default(inscrito)
  group_id             String?
  amount_paid          Decimal?          @db.Decimal(10, 2)
  payment_note         String?
  inseparable_with_id  String?
  move_with_partner    Boolean           @default(false)
  dietary_notified     Boolean           @default(false)
  arrives_for_dinner   Boolean           @default(true)
  last_meal_lunch      Boolean           @default(true)
  requests_text        String?
  requests_managed     Boolean           @default(false)
  checked_in_at        DateTime?
  room_id              String?

  event            Event        @relation(fields: [event_id], references: [id], onDelete: Cascade)
  person           Person       @relation(fields: [person_id], references: [id], onDelete: Cascade)
  group            Group?       @relation(fields: [group_id], references: [id], onDelete: SetNull)
  room             Room?        @relation(fields: [room_id], references: [id], onDelete: SetNull)

  @@unique([event_id, person_id])
  @@map("event_persons")

  activity_signups ActivitySignup[]
}

// ─── Room ────────────────────────────────────────────────────────────────────

enum GenderRestriction {
  mixed
  women
  men
}

model Room {
  id                    String            @id @default(cuid())
  event_id              String
  internal_number       String
  display_name          String?
  icon                  String?
  capacity              Int
  has_private_bathroom  Boolean           @default(false)
  gender_restriction    GenderRestriction @default(mixed)
  description           String?
  tags                  String[]          @default([])
  conflict_acknowledged Boolean           @default(false)
  locked                Boolean           @default(false)
  locked_reason         String?

  event         Event         @relation(fields: [event_id], references: [id], onDelete: Cascade)
  event_persons EventPerson[]

  @@map("rooms")
}

// ─── Group ───────────────────────────────────────────────────────────────────

model Group {
  id       String @id @default(cuid())
  event_id String
  name     String

  event   Event         @relation(fields: [event_id], references: [id], onDelete: Cascade)
  members EventPerson[]

  @@map("groups")
}

// ─── CentroShareToken ───────────────────────────────────────────────────────

model CentroShareToken {
  id         String   @id @default(cuid())
  event_id   String   @unique
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())

  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@map("centro_share_tokens")
}

// ─── Schedule ───────────────────────────────────────────────────────────────

enum ScheduleBlockType {
  common
  parallel
}

model ScheduleBlock {
  id         String            @id @default(cuid())
  event_id   String
  day_index  Int
  position   Int
  type       ScheduleBlockType
  time_label String?

  event      Event              @relation(fields: [event_id], references: [id], onDelete: Cascade)
  activities ScheduleActivity[]

  @@map("schedule_blocks")
}

model ScheduleActivity {
  id               String  @id @default(cuid())
  block_id         String
  title            String
  description      String?
  position         Int
  max_participants Int?
  closed           Boolean @default(false)

  block   ScheduleBlock    @relation(fields: [block_id], references: [id], onDelete: Cascade)
  signups ActivitySignup[]

  @@map("schedule_activities")
}

model ActivitySignup {
  id              String  @id @default(cuid())
  activity_id     String
  event_person_id String
  confirmed       Boolean @default(false)

  activity     ScheduleActivity @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  event_person EventPerson      @relation(fields: [event_person_id], references: [id], onDelete: Cascade)

  @@unique([activity_id, event_person_id])
  @@map("activity_signups")
}

// ─── PasswordResetToken ──────────────────────────────────────────────────────

model PasswordResetToken {
  id         String   @id @default(cuid())
  token      String   @unique
  email      String
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

// ─── UndoEntry ───────────────────────────────────────────────────────────────

enum UndoType {
  assign_person
  link_persons
}

model UndoEntry {
  id        String   @id @default(cuid())
  event_id  String
  batch_id  String
  type      UndoType
  snapshot  Json
  timestamp DateTime @default(now())

  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@map("undo_entries")
}

// ─── EventCollaborator ──────────────────────────────────────────────────────

model EventCollaborator {
  id       String @id @default(cuid())
  event_id String
  user_id  String

  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([event_id, user_id])
  @@map("event_collaborators")
}

// ─── AdminInviteToken ───────────────────────────────────────────────────────

model AdminInviteToken {
  id         String   @id @default(cuid())
  token      String   @unique
  created_by String
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("admin_invite_tokens")
}

// ─── RelationshipInvite ─────────────────────────────────────────────────────

enum RelationshipType {
  inseparable
  flexible
}

enum InviteStatus {
  pending
  accepted
  declined
  expired
}

model RelationshipInvite {
  id                String           @id @default(cuid())
  event_id          String
  sender_user_id    String
  recipient_email   String
  recipient_user_id String?
  relationship_type RelationshipType
  token             String           @unique
  status            InviteStatus     @default(pending)
  expires_at        DateTime
  created_at        DateTime         @default(now())
  resolved_at       DateTime?

  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@map("relationship_invites")
}
